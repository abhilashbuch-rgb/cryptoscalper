# ═══════════════════════════════════════════════════════════
# WICK.NETWORK — Environment Variable Configuration Matrix
# ═══════════════════════════════════════════════════════════
# Copy-paste into Vercel Dashboard → Settings → Environment Variables
# Mark each as Production / Preview / Development as needed

# ─── STRIPE (Fuel Onramp & Webhooks) ──────────────────────
STRIPE_SECRET_KEY=sk_live_...                    # Stripe Dashboard → Developers → API Keys
STRIPE_PUBLISHABLE_KEY=pk_live_...               # Stripe Dashboard → Developers → API Keys
STRIPE_WEBHOOK_SECRET=whsec_...                  # Stripe Dashboard → Developers → Webhooks → Signing secret

# ─── FIREBASE (Auth & Firestore) ──────────────────────────
FIREBASE_PROJECT_ID=wicknetwork
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-...@wicknetwork.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n"

# ─── FRONTEND ─────────────────────────────────────────────
FRONTEND_URL=https://wick.network

# ─── ANTHROPIC (AI Confidence Scoring) ────────────────────
ANTHROPIC_API_KEY=sk-ant-...                     # console.anthropic.com

# ─── POLYMARKET (Trade Execution) ─────────────────────────
POLYMARKET_PRIVATE_KEY=0x...                     # L1: Polygon wallet private key for signing
POLYMARKET_API_KEY=                              # L2: Generated via derive_api_key action
POLYMARKET_API_SECRET=                           # L2: Generated via derive_api_key action
POLYMARKET_PASSPHRASE=                           # L2: Generated via derive_api_key action
POLYMARKET_FUNDER_ADDRESS=0x...                  # Wallet holding USDC.e (if different from signer)

# ─── TRADING CONFIG ───────────────────────────────────────
DRY_RUN=true                                    # false = live trading
SCAN_INTERVAL_MS=120000                          # Market scan interval (ms)
HURDLE_RATE=1.03                                 # Min basket sum for NegRisk arb
LEG_SIZE_USD=50                                  # USD per leg in basket trades
MIN_BALANCE_USD=500                              # Min balance to operate

# ─── WIRE (News Wire Pipeline) ────────────────────────────
WIRE_WEBHOOK_SECRET=                             # HMAC secret for incoming wire webhooks
WIRE_MODE=sandbox                                # sandbox | live
WIRE_LEG_SIZE=25                                 # USD per wire-triggered position
WIRE_MIN_SCORE=3                                 # Min entity match score to trigger execution

# ─── ADMIN NOTIFICATIONS (Email via Resend) ──────────────
RESEND_API_KEY=re_...                            # resend.com → API Keys (free: 100 emails/day)
RESEND_AUDIENCE_ID=                              # resend.com → Audiences → your audience ID
ADMIN_EMAIL=abhilash.buch@gmail.com              # Where signup/invite notifications go

# ─── CRON / INTERNAL ──────────────────────────────────────
DEFAULT_USER_ID=                                 # Firestore user ID for calibration
CRON_SECRET=                                     # Bearer token for Vercel cron auth

# ─── INVITE SYSTEM ────────────────────────────────────────
ALLOWED_EMAILS=                                  # Comma-separated override list

# ─── VPS INGESTION ENGINE ─────────────────────────────────
ENGINE_PORT=3001                                 # Health endpoint port for the VPS engine
# COOLIFY_API_URL=https://api.wick.network       # Your US-East VPS endpoint
# COOLIFY_INTERNAL_SECRET=                        # Shared HMAC secret for Vercel→Coolify calls
# COOLIFY_HEALTH_URL=https://api.wick.network/health
