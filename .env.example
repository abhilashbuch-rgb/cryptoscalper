# Anthropic — get at console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Polymarket
# Polygon wallet private key for CLOB order execution (live mode only)
POLYMARKET_PRIVATE_KEY=0x...

# Trading config
DRY_RUN=true                        # Set to false for live trading
SCAN_INTERVAL_MS=120000             # How often to scan markets (2 min default)
HURDLE_RATE=1.03                    # Minimum basket sum to trigger NegRisk arb
LEG_SIZE_USD=50                     # USD per leg in basket trades
MIN_BALANCE_USD=500                 # Minimum balance to operate

# Firebase Admin SDK — get from Firebase Console → Project Settings → Service Accounts
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Nightly Calibration
DEFAULT_USER_ID=                    # Firestore user doc ID for calibration target
CRON_SECRET=                        # Bearer token to authenticate Vercel cron hits

# Invite-only access control (comma-separated emails, or manage via Firestore 'allowlist' collection)
ALLOWED_EMAILS=
