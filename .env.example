# Anthropic — get at console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Robinhood bearer token
# Get it by logging into robinhood.com, opening DevTools → Network,
# filtering for "api.robinhood.com", and copying the Authorization header value.
RH_ACCESS_TOKEN=

# Trading config
DRY_RUN=true                        # Set to false for live trading
SYMBOLS=BTC,ETH,DOGE,SOL            # Comma-separated crypto symbols to watch
POLL_INTERVAL_MS=30000              # How often to poll prices (30s default)
MAX_POSITION_USD=100                # Max $ per position
TAKE_PROFIT_PCT=1.5                 # Take profit at 1.5% gain
STOP_LOSS_PCT=0.5                   # Cut loss at 0.5% drawdown
